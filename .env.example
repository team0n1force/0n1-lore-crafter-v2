# Example environment file
# Copy this to .env.local and fill in your actual API keys

# ============================================================
# API KEYS (required for features to work)
# ============================================================

# OpenSea API Key - Get from https://opensea.io/account#api
OPENSEA_API_KEY=your_opensea_api_key_here

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Together AI API Key - Get from https://api.together.xyz/
TOGETHER_API_KEY=your_together_api_key_here

# Supabase (optional — enables cloud persistence for souls)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================
# AUTH SECURITY (REQUIRED for production — app will crash without these)
# ============================================================

# JWT secret for signing auth tokens — min 32 characters, random string
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT refresh token secret — must be different from JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_secret

# Session duration in hours (default: 24)
SESSION_DURATION_HOURS=24

# Challenge expiry in minutes (default: 5)
CHALLENGE_EXPIRY_MINUTES=5

# ============================================================
# DEV MODE (never enable in production)
# ============================================================

# Set to true ONLY in development to bypass wallet signature verification
# WARNING: This lets anyone authenticate as any wallet address!
AUTH_DEV_MODE=false
